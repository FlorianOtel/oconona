{
  "_comment": "Orchestra hooks to merge into ~/.config/opencode/settings.json. Run deploy.sh to apply automatically, or merge manually with jq (see README).",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/opencode/scripts/orchestra-hook.sh start"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/opencode/scripts/orchestra-hook.sh end"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/opencode/scripts/orchestra-hook.sh compact"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/opencode/scripts/orchestra-hook.sh stop"
          }
        ]
      }
    ]
  }
}
